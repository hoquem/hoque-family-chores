rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // The requesting user's profile document.
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isFamilyMember(familyId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.memberIds;
    }

    match /users/{userId} {
      // Own profile always readable; family members can read each other
      // (member lists, points display).
      allow read: if isSignedIn()
        && (request.auth.uid == userId
            || resource.data.familyId == me().familyId);
      // A new profile starts with zero stars; points are never client-set.
      allow create: if isSignedIn() && request.auth.uid == userId
        && (!('points' in request.resource.data)
            || request.resource.data.points == 0);
      // Self-updates (profile edits, joining a family) or a parent/guardian in
      // the same family (e.g. role changes). `points` is OFF LIMITS to every
      // client: all star changes (earning, spending, refunds) go through the
      // Cloud Functions, which write points with admin privileges. This is what
      // keeps the economy honest — otherwise a child could set their own stars.
      allow update: if isSignedIn()
        && request.resource.data.points == resource.data.points
        && (request.auth.uid == userId
            || (resource.data.familyId == me().familyId
                && me().role in ['parent', 'guardian']));
      allow delete: if isSignedIn() && request.auth.uid == userId;

      match /notifications/{notificationId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // A join request proves the requester holds a valid invite CODE for this
    // family: it can only be created if the supplied code resolves (via
    // familyInvites) to this family. The family `get` and the memberIds
    // self-add below both require this doc, so knowing a family's id alone is
    // no longer enough to read or join it — you need the invite code.
    function hasJoinRequest(familyId) {
      return exists(/databases/$(database)/documents/families/$(familyId)/joinRequests/$(request.auth.uid));
    }

    match /families/{familyId} {
      // Readable by members, or by someone mid-join who has proven the code via
      // a join request. Not open to every signed-in user: the family doc
      // carries member ids and the invite code, so an id-only read is a leak.
      allow get: if isSignedIn()
        && (request.auth.uid in resource.data.memberIds
            || hasJoinRequest(familyId));
      allow list: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn()
        && request.resource.data.creatorId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      // Members may update; a non-member may only add themselves, and only with
      // a join request (which required the invite code).
      allow update: if isSignedIn()
        && (request.auth.uid in resource.data.memberIds
            || (request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['memberIds', 'updatedAt'])
                && request.resource.data.memberIds.hasAll(resource.data.memberIds)
                && request.auth.uid in request.resource.data.memberIds
                && hasJoinRequest(familyId)));
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;

      match /joinRequests/{uid} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        allow create: if isSignedIn()
          && request.auth.uid == uid
          && exists(/databases/$(database)/documents/familyInvites/$(request.resource.data.code))
          && get(/databases/$(database)/documents/familyInvites/$(request.resource.data.code)).data.familyId == familyId;
        allow update, delete: if false;
      }

      match /tasks/{taskId} {
        allow read, write: if isFamilyMember(familyId);
      }

      // Rewards a family offers. Anyone in the family may add or remove one —
      // a family is peers, not a hierarchy, and a child proposing "bike ride
      // with Dad" is the feature working.
      match /rewards/{rewardId} {
        allow read, write: if isFamilyMember(familyId);
      }

      // Claims against those rewards.
      //
      // Deliberately as open as tasks, and worth saying why rather than
      // leaving it to look lazy. The interesting rules here are not
      // expressible at this layer: "you may only settle your own claim" and
      // "a settled claim cannot be settled twice" both depend on comparing a
      // write against existing state and on who claimed it. Those live in
      // SettleRedemptionUseCase, with tests.
      //
      // What this layer must do is keep one family's promises out of another
      // family's hands, and it does. Within a family, the stars are the real
      // control: you cannot claim what you have not earned, and earning
      // requires someone else to sign off your chore.
      match /redemptions/{redemptionId} {
        // Members can see the family's claims, but claiming and settling both
        // move stars, so they only happen via the Cloud Functions (admin) — a
        // client can neither record a claim it didn't pay for nor refund one.
        allow read: if isFamilyMember(familyId);
        allow write: if false;
      }
    }

    // Invite-code lookup documents: fetchable by code, never listable, and
    // immutable once created (no hijacking an existing code).
    match /familyInvites/{code} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn()
        && request.resource.data.familyId is string;
      allow update, delete: if false;
    }

    // Photo-proof completions (not yet surfaced in the UI).
    match /questCompletions/{completionId} {
      allow read, write: if isSignedIn()
        && isFamilyMember(request.resource.data.familyId);
    }

    // User feedback — APPEND-ONLY. A signed-in client may only submit; it can
    // never read, edit, or delete. Read it in the Firebase console.
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // Usage analytics — APPEND-ONLY. A signed-in client may only add an event;
    // it can never read, edit, or delete one. Analysis happens in
    // BigQuery/Looker Studio, not the app. Events carry the pseudonymous uid and
    // low-cardinality params only — no PII (children are users).
    match /analyticsEvents/{eventId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }
  }
}
